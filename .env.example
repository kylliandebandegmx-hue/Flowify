# Shared local development values. Copy the files in each app when needed.

# apps/web
VITE_POCKETBASE_URL=https://flowify-pocketbase.onrender.com
# Service apps/api pour lecture/telechargement via yt-dlp.
# Utilise une URL HTTPS en production (GitHub Pages/APK).
VITE_FLOWIFY_API_URL=http://localhost:8787

# apps/api
PORT=8787
YOUTUBE_API_KEY=
# YOUTUBE_API_KEY is optional because the app can send it with X-YouTube-Api-Key.
YTDLP_PATH=yt-dlp
CORS_ORIGIN=http://localhost:5173
DOWNLOAD_DIR=.flowify-downloads
