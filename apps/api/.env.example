PORT=8787
YOUTUBE_API_KEY=
# YOUTUBE_API_KEY is optional because the app can send it with X-YouTube-Api-Key.
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
YTDLP_JS_RUNTIME=deno
# Optional but recommended on cloud hosts when YouTube asks "confirm you're not a bot".
# Put a base64-encoded Netscape cookies.txt export here.
YTDLP_COOKIES_BASE64=
CORS_ORIGIN=http://localhost:5173
DOWNLOAD_DIR=.flowify-downloads
