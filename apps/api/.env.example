PORT=8787
YOUTUBE_API_KEY=
# YOUTUBE_API_KEY is optional because the app can send it with X-YouTube-Api-Key.
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
YTDLP_JS_RUNTIME=deno
YTDLP_REMOTE_COMPONENTS=ejs:github
# Optional but recommended on cloud hosts when YouTube asks "confirm you're not a bot".
# Put a base64-encoded Netscape cookies.txt export here.
YTDLP_COOKIES_BASE64=
CORS_ORIGIN=http://localhost:5173
DOWNLOAD_DIR=.flowify-downloads

# Cloudflare R2 pour l'onglet Cloud.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=flowify-music
# Optionnel: domaine public R2/r2.dev pour lire sans proxy API.
R2_PUBLIC_BASE_URL=
CLOUD_UPLOAD_LIMIT=80mb
